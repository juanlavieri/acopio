# ---------------------------------------------------------------------------
# Acopio environment configuration
# Copy to ".env" for local development. In production (Render) set these as
# environment variables in the dashboard / via render.yaml.
# ---------------------------------------------------------------------------

# App
APP_NAME=Acopio
PORT=8000
# Comma-separated allowed CORS origins. "*" is fine for the single-service deploy.
CORS_ORIGINS=*

# Secret used to sign/seed session tokens. CHANGE THIS in production.
# Render can auto-generate it (see render.yaml).
SECRET_KEY=change-me-in-production-please

# The first account created becomes the COUNTRY MANAGER (top of the hierarchy).
# You can either register it in the UI on first run, or have it auto-created on a
# fresh database by setting these (keep the password OUT of git — set it here
# locally or in your host's dashboard as a secret):
# [email protected]
# BOOTSTRAP_ADMIN_NAME=Maryanne Goiri
# BOOTSTRAP_ADMIN_PASSWORD=change-me

# The collection-center country/region seeded on first run.
DEFAULT_COUNTRY=Venezuela
DEFAULT_REGION=Nacional
DEFAULT_CENTER=Centro Principal

# Database. If DATABASE_URL is unset we fall back to a local SQLite file
# (data/acopio.db) so the app runs with zero setup. Render provides a Postgres
# URL automatically when you attach a database.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/acopio

# OpenAI: powers normalization, the agent, semantic dedup and voice transcription.
# WITHOUT a key the app still runs using offline heuristics + librarian's
# hashing embedder, but the AI features are much smarter with it set.
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Where librarian stores its catalog + vector index, and where uploads land.
DATA_DIR=data
